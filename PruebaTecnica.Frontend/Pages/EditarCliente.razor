@page "/clientes/editar/{Id:int}"
@using PruebaTecnica.Frontend.Models
@using PruebaTecnica.Frontend.Services
@inject IClienteService ClienteService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Cliente</h4>
                </div>
                <div class="card-body p-4">
                    
                    @if (cargandoDatos)
                    {
                        <div class="text-center my-4">
                            <div class="spinner-border text-warning" role="status"></div>
                            <p>Cargando datos del cliente...</p>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger" role="alert">
                                @mensajeError
                            </div>
                        }

                        <EditForm Model="clienteEditar" OnValidSubmit="GuardarCambios">
                            <DataAnnotationsValidator />

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Nombre Completo *</label>
                                    <InputText class="form-control" @bind-Value="clienteEditar.Nombre" required />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Identificación (RTN/DNI) *</label>
                                    <InputText class="form-control" @bind-Value="clienteEditar.Identificacion" required />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Teléfono</label>
                                    <InputText class="form-control" @bind-Value="clienteEditar.Telefono" />
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="form-label fw-bold">Correo Electrónico</label>
                                    <InputText type="email" class="form-control" @bind-Value="clienteEditar.Correo" />
                                </div>
                            </div>
                            
                            <div class="mb-4 form-check form-switch">
                                <InputCheckbox class="form-check-input" id="estadoSwitch" @bind-Value="clienteEditar.Estado" />
                                <label class="form-check-label fw-bold" for="estadoSwitch">
                                    Cliente Activo
                                </label>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <a href="/clientes" class="btn btn-secondary">Cancelar</a>
                                <button type="submit" class="btn btn-warning" disabled="@cargando">
                                    @if (cargando)
                                    {
                                        <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                        <span> Actualizando...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-pencil-square"></i> <span>Actualizar Cliente</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private ClienteDto clienteEditar = new ClienteDto();
    private bool cargando = false;
    private bool cargandoDatos = true;
    private string mensajeError = string.Empty;

    protected override async Task OnInitializedAsync()
    {        
        clienteEditar = await ClienteService.ObtenerClientePorIdAsync(Id);
        cargandoDatos = false;
    }

    private async Task GuardarCambios()
    {
        cargando = true;
        mensajeError = string.Empty;        
        
        var exito = await ClienteService.ActualizarClienteAsync(clienteEditar);
        
        if (exito)
        {
            NavigationManager.NavigateTo("/clientes");
        }
        else
        {
            mensajeError = "No se pudo actualizar el cliente.";
            cargando = false;
        }
    }
}
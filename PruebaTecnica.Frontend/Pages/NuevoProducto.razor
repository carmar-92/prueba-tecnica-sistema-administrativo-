@page "/productos/nuevo"
@using PruebaTecnica.Frontend.Models
@using PruebaTecnica.Frontend.Services
@inject IProductoService ProductoService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Registrar Nuevo Producto</h4>
                </div>
                <div class="card-body p-4">
                    
                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="alert alert-danger" role="alert">
                            @mensajeError
                        </div>
                    }

                    <EditForm Model="productoNuevo" OnValidSubmit="GuardarProducto">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Código *</label>
                                <InputText class="form-control" @bind-Value="productoNuevo.Codigo" placeholder="Ej: PROD-001" required />
                            </div>

                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-bold">Nombre del Producto *</label>
                                <InputText class="form-control" @bind-Value="productoNuevo.Nombre" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Precio Unitario *</label>
                                <div class="input-group">
                                    <span class="input-group-text">L.</span>
                                    <InputNumber class="form-control" @bind-Value="productoNuevo.Precio" step="0.01" required />
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Stock Inicial *</label>
                                <InputNumber class="form-control" @bind-Value="productoNuevo.Stock" required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/productos" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success" disabled="@cargando">
                                @if (cargando)
                                {
                                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                    <span> Guardando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-save"></i> <span>Guardar Producto</span>
                                }
                            </button>
                        </div>
                    </EditForm>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ProductoDto productoNuevo = new ProductoDto();
    private bool cargando = false;
    private string mensajeError = string.Empty;

    private async Task GuardarProducto()
    {
        cargando = true;
        mensajeError = string.Empty;
        
        var exito = await ProductoService.CrearAsync(productoNuevo);
        
        if (exito)
        {
            NavigationManager.NavigateTo("/productos");
        }
        else
        {
            mensajeError = "No se pudo guardar el producto. Verifica que los datos sean correctos.";
            cargando = false;
        }
    }
}
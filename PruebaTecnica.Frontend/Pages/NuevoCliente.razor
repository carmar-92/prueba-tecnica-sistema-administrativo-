@page "/clientes/nuevo"
@using PruebaTecnica.Frontend.Models
@using PruebaTecnica.Frontend.Services
@inject IClienteService ClienteService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nuevo Cliente</h4>
                </div>
                <div class="card-body p-4">
                    
                    <EditForm Model="clienteNuevo" OnValidSubmit="GuardarCliente">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre Completo *</label>
                                <InputText class="form-control" @bind-Value="clienteNuevo.Nombre" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Identificación (RTN/DNI) *</label>
                                <InputText class="form-control" @bind-Value="clienteNuevo.Identificacion" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Teléfono</label>
                                <InputText class="form-control" @bind-Value="clienteNuevo.Telefono" />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Correo Electrónico</label>
                                <InputText type="email" class="form-control" @bind-Value="clienteNuevo.Correo" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/clientes" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success" disabled="@cargando">
                                @if (cargando)
                                {
                                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                    <span> Guardando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-save"></i> <span>Guardar Cliente</span>
                                }
                            </button>
                        </div>
                    </EditForm>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ClienteDto clienteNuevo = new ClienteDto();
    private bool cargando = false;
    private string mensajeError = string.Empty;

   private async Task GuardarCliente()
    {
        cargando = true;
        mensajeError = string.Empty;        
        
        clienteNuevo.FechaRegistro = DateTime.Now;         
        
        var exito = await ClienteService.CrearClienteAsync(clienteNuevo);
        
        if (exito)
        {
            NavigationManager.NavigateTo("/clientes");
        }
        else
        {
            mensajeError = "No se pudo guardar el cliente.";
            cargando = false;
        }
    }
}
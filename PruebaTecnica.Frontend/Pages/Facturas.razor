@page "/facturacion"
@using PruebaTecnica.Frontend.Models
@using PruebaTecnica.Frontend.Services
@inject IFacturaService FacturaService

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history"></i> Historial de Facturas</h2>

    <a href="/facturas/nueva" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Factura
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <div class="input-group" style="max-width: 400px;">
            <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Buscar por N° de Factura o ID Cliente..." @bind="terminoBusqueda" @bind:event="oninput" />
        </div>
    </div>

    <div class="card-body p-0">
        @if (listaFacturas == null)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Cargando historial de facturación...</p>
            </div>
        }
        else if (!listaFacturas.Any())
        {
            <div class="alert alert-info m-3">Aún no se han emitido facturas en el sistema.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° Factura</th>
                            <th>Fecha de Emisión</th>
                            <th>ID Cliente</th>
                            <th class="text-end">Subtotal</th>
                            <th class="text-end">ISV (15%)</th>
                            <th class="text-end">Total Pagado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!facturasFiltradas.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No se encontraron facturas con esa búsqueda.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var factura in facturasFiltradas)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">FAC-@factura.IdFacturas.ToString("D4")</span></td>
                                    <td>@factura.Fecha.ToString("dd/MM/yyyy hh:mm tt")</td>
                                    <td>@factura.IdClientes</td>
                                    <td class="text-end text-muted">L. @factura.Subtotal.ToString("N2")</td>
                                    <td class="text-end text-muted">L. @factura.ISV.ToString("N2")</td>
                                    <td class="text-end fw-bold text-success">L. @factura.Total.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<FacturaDto>? listaFacturas;
    private string terminoBusqueda = string.Empty;

    
    private IEnumerable<FacturaDto> facturasFiltradas =>
        string.IsNullOrWhiteSpace(terminoBusqueda)
            ? listaFacturas ?? new List<FacturaDto>()
            : listaFacturas!.Where(f =>
                f.IdFacturas.ToString().Contains(terminoBusqueda) ||
                $"FAC-{f.IdFacturas:D4}".Contains(terminoBusqueda, StringComparison.OrdinalIgnoreCase) || 
                f.IdClientes.ToString().Contains(terminoBusqueda)); 

    protected override async Task OnInitializedAsync()
    {
        listaFacturas = await FacturaService.ListarAsync();
    }
}
@page "/clientes"
@using PruebaTecnica.Frontend.Models
@using PruebaTecnica.Frontend.Services
@inject IClienteService ClienteService
@inject IJSRuntime JsRuntime

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Nuestros Clientes</h2>
    <a href="/clientes/nuevo" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (listaClientes == null)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Cargando clientes...</p>
            </div>
        }
        else if (!listaClientes.Any())
        {
            <div class="alert alert-info">No hay clientes registrados en el sistema.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Identificación</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in listaClientes)
                    {
                        <tr>
                            <td>@cliente.Id</td>
                            <td>@cliente.Nombre</td>
                            <td>@cliente.Identificacion</td>
                            <td>
                                @if (cliente.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a href="/clientes/editar/@cliente.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(cliente.Id, cliente.Nombre)">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </td>                           
                        </tr>

                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<ClienteDto>? listaClientes;

    protected override async Task OnInitializedAsync()
    {        
        listaClientes = await ClienteService.ObtenerClientesAsync();
    }

    private async Task ConfirmarEliminar(int id, string nombre)
    {        
        var confirmado = await JsRuntime.InvokeAsync<bool>("confirm", $"¿Estás seguro de que deseas eliminar al cliente {nombre}?");

        if (confirmado)
        {
            var exito = await ClienteService.EliminarClienteAsync(id);
            if (exito)
            {                
                listaClientes = await ClienteService.ObtenerClientesAsync();
            }
        }
    }
}

